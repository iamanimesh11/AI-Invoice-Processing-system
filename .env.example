# ============================================================
# Invoice AI Pipeline — Environment Template
# Copy to .env and fill in real values. Never commit .env.
# Run: scripts/generate_secrets.sh to auto-generate keys.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=invoice_db
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── LLM Provider ─────────────────────────────────────────────
# Options: openai | local
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
# Required when LLM_PROVIDER=local (Ollama endpoint)
LOCAL_LLM_URL=http://host.docker.internal:11434

# ── Airflow ───────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_FERNET_KEY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_airflow_password

# ── App Settings ──────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
OCR_DPI=300
